{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "projectName": {
      "value": "laps-prod"
    },
    "location": {
      "value": "germanywestcentral"
    },
    "customDomain": {
      "value": ""
    },
    "authClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscriptionId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vault>"
        },
        "secretName": "laps-auth-client-secret"
      }
    }
  }
}
